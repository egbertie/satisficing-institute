      "sub_dimensions": {
        "positive_test": {
          "name": "正例测试",
          "weight": 0.40,
          "thresholds": {
            "A": 95,
            "B": 85,
            "C": 70,
            "D": 0
          }
        },
        "negative_test": {
          "name": "负例测试",
          "weight": 0.30,
          "thresholds": {
            "A": 5,
            "B": 15,
            "C": 30,
            "D": 100
          }
        },
        "boundary_test": {
          "name": "边界测试",
          "weight": 0.30,
          "thresholds": {
            "A": 95,
            "B": 85,
            "C": 70,
            "D": 0
          }
        }
      }
    },
    "effectiveness": {
      "name": "有效性评估",
