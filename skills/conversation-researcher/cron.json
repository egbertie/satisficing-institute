{
  "jobs": [
    {
      "name": "conversation-research-daily",
      "schedule": "0 23 * * *",
      "command": "cd /root/.openclaw/workspace/skills/conversation-researcher && python3 scripts/research-runner.py",
      "description": "每日对话研究（需要设置RESEARCH_TOPIC环境变量）",
      "enabled": false
    }
  ],
  "triggers": {
    "manual": {
      "command": "python3 skills/conversation-researcher/scripts/research-runner.py '研究主题'",
      "env_vars": ["RESEARCH_TOPIC", "RESEARCH_DEPTH", "RESEARCH_FRESHNESS"]
    }
  }
}
