{
  "jobs": [
    {
      "name": "token-morning-brief",
      "schedule": "7 9 * * *",
      "command": "cd /root/.openclaw/workspace/skills/token-budget-enforcer && python3 scripts/enforcer_runner.py budget",
      "description": "每日09:07显示Token预算看板"
    },
    {
      "name": "token-realtime-monitor",
      "schedule": "*/10 * * * *",
