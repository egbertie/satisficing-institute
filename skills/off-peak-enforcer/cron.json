{
  "name": "off-peak-enforcer",
  "description": "错峰规则强制执行 - 强制执行错峰任务调度",
  "version": "1.0",
  "jobs": [
    {
      "name": "off-peak-enforcer",
      "schedule": "*/10 * * * *",
      "command": "bash /root/.openclaw/workspace/skills/off-peak-enforcer/scripts/off-peak-enforcer.sh",
      "enabled": true,
      "description": "每10分钟检查错峰队列和执行条件"
    },
    {
      "name": "off-peak-queue-processor",
      "schedule": "0 */2 * * *",
      "command": "echo '处理错峰队列: $(date)' >> /root/.openclaw/workspace/skills/off-peak-enforcer/logs/queue-processor.log",
      "enabled": true,
      "description": "每2小时处理错峰队列任务"
    },
    {
      "name": "off-peak-daily-report",
      "schedule": "0 9 * * *",
      "command": "echo '错峰日报: $(date)' >> /root/.openclaw/workspace/skills/off-peak-enforcer/logs/daily-report.log",
      "enabled": true,
      "description": "每日9点生成错峰执行报告"
    }
  ]
}
