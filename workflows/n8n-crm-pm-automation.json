{
  "name": "满意解研究所 CRM+PM 自动化",
  "nodes": [
    {
      "parameters": {},
      "id": "trigger-daily-morning",
      "name": "每日晨报触发",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "daily-report"
    },
    {
      "parameters": {
        "operation": "getAll",
        "databaseId": "={{ $env.NOTION_CANDIDATES_DB }}",
        "filter": {
          "property": "下次跟进",
          "date": {
            "equals": "{{ $today }}"
          }
        }
      },
      "id": "notion-query-today",
      "name": "查询今日待跟进",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2,
      "position": [450, 300]
    },
    {
      "parameters": {
        "operation": "getAll",
        "databaseId": "={{ $env.NOTION_TASKS_DB }}",
        "filter": {
          "and": [
            {
              "property": "截止日期",
              "date": {
                "equals": "{{ $today }}"
              }
            },
            {
              "property": "状态",
              "select": {
                "does_not_equal": "已完成"
              }
            }
          ]
        }
      },
      "id": "notion-query-tasks",
      "name": "查询今日任务",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2,
      "position": [450, 500]
    },
    {
      "parameters": {
        "jsCode": "// 整合数据生成晨报\nconst followups = $input.all()[0].json.results || [];\nconst tasks = $input.all()[1].json.results || [];\n\nconst report = {\n  date: new Date().toLocaleDateString('zh-CN'),\n  followups: followups.map(f => ({\n    name: f.properties.姓名.title[0]?.text.content,\n    company: f.properties.公司.rich_text[0]?.text.content,\n    action: f.properties.下次行动.rich_text[0]?.text.content\n  })),\n  tasks: tasks.map(t => ({\n    title: t.properties.任务名称.title[0]?.text.content,\n    assignee: t.properties.负责人.people[0]?.name,\n    priority: t.properties.优先级.select?.name\n  })),\n  stats: {\n    totalFollowups: followups.length,\n    totalTasks: tasks.length,\n    p0Tasks: tasks.filter(t => t.properties.优先级.select?.name === 'P0').length\n  }\n};\n\nreturn [{ json: report }];"
      },
      "id": "code-generate-report",
      "name": "生成晨报数据",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 400]
    },
    {
      "parameters": {
        "content": "={{ $json.report }}",
        "messageType": "text"
      },
      "id": "feishu-send-report",
      "name": "发送飞书晨报",
      "type": "n8n-nodes-base.feishu",
      "typeVersion": 1,
      "position": [850, 400]
    },
    {
      "parameters": {},
      "id": "trigger-new-candidate",
      "name": "新候选人触发",
      "type": "n8n-nodes-base.notionTrigger",
      "typeVersion": 1,
      "position": [250, 700],
      "webhookId": "new-candidate"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-1",
              "leftValue": "={{ $json.event }}",
              "rightValue": "created",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        }
      },
      "id": "if-new-candidate",
      "name": "判断新建?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [450, 700]
    },
    {
      "parameters": {
        "content": "🎯 新候选人入库\n\n姓名: {{ $json.properties.姓名.title[0].text.content }}\n公司: {{ $json.properties.公司.rich_text[0].text.content }}\n职位: {{ $json.properties.职位.rich_text[0].text.content }}\n来源: {{ $json.properties.来源.select.name }}\n\n分配给: {{ $json.properties.分配给.people[0].name }}\n\n请及时安排初筛！",
        "messageType": "text"
      },
      "id": "feishu-notify-team",
      "name": "通知评估团队",
      "type": "n8n-nodes-base.feishu",
      "typeVersion": 1,
      "position": [650, 600]
    },
    {
      "parameters": {
        "operation": "create",
        "databaseId": "={{ $env.NOTION_TASKS_DB }}",
        "properties": {
          "任务名称": {
            "title": [
              {
                "text": {
                  "content": "="={{ '初筛: ' + $json.properties.姓名.title[0].text.content }}"="
                }
              }
            ]
          },
          "关联候选人": {
            "relation": [
              {
                "id": "={{ $json.id }}"
              }
            ]
          },
          "负责人": {
            "people": [
              {
                "id": "={{ $json.properties.分配给.people[0].id }}"
              }
            ]
          },
          "截止日期": {
            "date": {
              "start": "={{ $today.plus(7, 'days').toISODate() }}"
            }
          },
          "优先级": {
            "select": {
              "name": "P1"
            }
          }
        }
      },
      "id": "notion-create-task",
      "name": "创建初筛任务",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2,
      "position": [650, 800]
    },
    {
      "parameters": {},
      "id": "trigger-task-due",
      "name": "任务到期触发",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 1000],
      "webhookId": "task-reminder"
    },
    {
      "parameters": {
        "operation": "getAll",
        "databaseId": "={{ $env.NOTION_TASKS_DB }}",
        "filter": {
          "and": [
            {
              "property": "截止日期",
              "date": {
                "equals": "={{ $today.plus(1, 'day').toISODate() }}"
              }
            },
            {
              "property": "状态",
              "select": {
                "does_not_equal": "已完成"
              }
            }
          ]
        }
      },
      "id": "notion-query-due-tasks",
      "name": "查询即将到期任务",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2,
      "position": [450, 1000]
    },
    {
      "parameters": {
        "content": "⏰ 任务即将到期\n\n任务: {{ $json.properties.任务名称.title[0].text.content }}\n负责人: {{ $json.properties.负责人.people[0].name }}\n截止日期: {{ $json.properties.截止日期.date.start }}\n\n请及时处理！",
        "messageType": "text"
      },
      "id": "feishu-remind-assignee",
      "name": "提醒负责人",
      "type": "n8n-nodes-base.feishu",
      "typeVersion": 1,
      "position": [650, 1000]
    }
  ],
  "connections": {
