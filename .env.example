# API Keys - 配置模板
# 复制此文件为 .env 并填入你的实际API密钥
# 注意: .env 文件应添加到 .gitignore，不要提交到版本控制

# ============================================
# TODO-001: GitHub Models (GPT-4o免费访问)
# 注册: https://github.com/marketplace/models
# 免费额度: GPT-4o 10 RPM / 50 RPD
# ============================================
GITHUB_MODELS_PAT=ghp_your_github_personal_access_token_here

# ============================================
# TODO-002: Perplexity API (AI搜索)
# 注册: https://www.perplexity.ai/settings/api
# 免费额度: Pro用户每月$5积分 (约300-500次)
# ============================================
PERPLEXITY_API_KEY=pplx_your_perplexity_api_key_here

# ============================================
# TODO-003: Jina AI (搜索底座API)
# 注册: https://jina.ai/?sui=apikey
# 免费额度: 每天1000次 (无需信用卡)
# ============================================
JINA_API_KEY=jina_your_jina_api_key_here
