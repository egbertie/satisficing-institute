{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "合伙人案例库数据规范",
  "description": "用于标准化录入创业合伙人案例的数据结构",
  "type": "object",
  "required": ["case_id", "case_name", "industry", "result"],
  "properties": {
    "case_id": {
      "type": "string",
      "description": "案例唯一标识，格式：CASE-XXX",
      "pattern": "^CASE-[0-9]{3}$"
    },
    "case_name": {
      "type": "string",
      "description": "案例名称",
      "minLength": 1,
      "maxLength": 100
    },
    "industry": {
      "type": "string",
      "description": "行业领域",
      "enum": ["硬科技", "AI", "生物医药", "新能源", "半导体", "消费", "企业服务", "金融科技", "其他"]
    },
    "occurrence_time": {
      "type": "string",
      "description": "发生时间",
      "pattern": "^[0-9]{4}(-[0-9]{2})?$"
    },
    "info_source": {
      "type": "string",
      "description": "信息来源",
      "enum": ["公开报道", "深度访谈", "间接了解", "内部资料"]
    },
    "confidentiality": {
      "type": "string",
      "description": "脱敏程度",
      "enum": ["完全公开", "部分脱敏", "高度敏感"]
    },
    "partners": {
      "type": "object",
      "description": "合伙人信息",
      "properties": {
        "count": {
          "type": "integer",
          "description": "合伙人数量",
          "minimum": 1,
          "maximum": 10
        },
        "roles": {
          "type": "array",
          "description": "角色分工",
          "items": {
            "type": "string",
            "enum": ["CEO", "CTO", "COO", "CFO", "CMO", "首席科学家", "产品负责人", "技术负责人", "运营负责人", "其他"]
          }
        },
        "background_types": {
          "type": "array",
          "description": "背景类型",
          "items": {
            "type": "string",
            "enum": ["学术", "产业", "连续创业", "跨界", "大厂高管", "投资人"]
          }
        },
        "relationship_type": {
          "type": "string",
          "description": "关系类型",
          "enum": ["师生", "同学", "前同事", "陌生人", "朋友", "家人", "创业伙伴"]
        }
      }
    },
    "key_decisions": {
      "type": "object",
      "description": "关键决策点",
      "properties": {
        "equity_design": {
          "type": "object",
          "description": "股权设计",
          "properties": {
            "initial_ratio": {
              "type": "string",
              "description": "初始股权比例"
            },
            "changes": {
              "type": "string",
              "description": "后续变化"
            }
          }
        },
        "tech_route": {
          "type": "string",
          "description": "技术路线选择"
        },
        "financing_decision": {
          "type": "string",
          "description": "融资决策"
        },
        "exit_decision": {
          "type": "string",
          "description": "退出/分手决策"
        }
      }
    },
    "outcome_analysis": {
      "type": "object",
      "description": "成败分析",
      "properties": {
        "result": {
          "type": "string",
          "description": "结果",
          "enum": ["成功", "失败", "进行中", "转型", "收购退出", "IPO"]
        },
        "success_factors": {
          "type": "array",
          "description": "关键成功因素（1-3条）",
          "items": {
            "type": "string"
          },
          "maxItems": 3
        },
        "failure_factors": {
          "type": "array",
          "description": "关键失败因素（1-3条）",
          "items": {
            "type": "string"
          },
          "maxItems": 3
        },
        "warning_signals": {
          "type": "array",
          "description": "预警信号（早期可识别的信号）",
          "items": {
            "type": "string"
          }
        },
        "lessons": {
          "type": "array",
          "description": "可借鉴的教训",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "satisficing_link": {
      "type": "object",
      "description": "与满意解的关联",
      "properties": {
        "totem_applicable": {
          "type": "array",
          "description": "适用的五路图腾",
          "items": {
            "type": "string",
            "enum": ["虎-权威决策", "豹-敏捷执行", "象-资源整合", "狐-策略博弈", "羊-团队凝聚"]
          }
        },
        "risk_indicators": {
          "type": "array",
          "description": "对应的风险预警指标",
          "items": {
            "type": "string"
          }
        },
        "simulation_applicable": {
          "type": "array",
          "description": "可用于沙盘模拟的环节",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "元数据",
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "author": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}